{
  "expo": {
    "name": "Hapyjo Ltd",
    "slug": "hapyjo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/hapyjo_playstore_icon_v2_1024.png",
    "scheme": "hapyjo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/hapyjo_playstore_icon_v2_1024.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "package": "com.hapyjo.attendance",
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/hapyjo_playstore_icon_v2_1024.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/hapyjo_playstore_icon_v2_1024.png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#1e3a8a"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Hapyjo to access the camera for GPS-tagged photos."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Hapyjo to use your location for GPS stamps on photos."
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/hapyjo_playstore_icon_v2_1024.png",
          "color": "#2563eb",
          "sounds": [],
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7e8c7f84-33b9-4891-9d3c-a15b253f962d"
      }
    }
  }
}